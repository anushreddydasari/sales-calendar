# Copy to .env and fill in (cp .env.example .env)
# NEVER commit .env — it is listed in .gitignore

# HubSpot (required for sync)
HUBSPOT_ACCESS_TOKEN=

# Optional: app port
# PORT=3001

# SQLite file path (relative to backend/ folder, or absolute path)
# Default if omitted: data/sales-calendar.db
# SQLITE_DB_PATH=data/sales-calendar.db
# SQLITE_DB_PATH=C:/data/my-sales-calendar.db

# ── App login (optional) ──
# If BOTH are set, the UI requires sign-in and all /api routes except
# /api/auth/* and /api/health require a session token.
# Important: no spaces around = (e.g. KEY=value not KEY = value)
APP_LOGIN_USERNAME=
APP_LOGIN_PASSWORD=

# Label shown in the header dropdown (default: same as username)
# APP_LOGIN_DISPLAY_NAME=SalesCalendar

# Optional: secret for signing session tokens (min 16 chars).
# If omitted, a derived secret is used from username+password.
# APP_AUTH_SECRET=
